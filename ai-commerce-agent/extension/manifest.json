{
  "manifest_version": 3,
  "name": "AI Commerce Agent",
  "version": "1.1.0",
  "description": "AI-Powered JD product search with voice input",
  "permissions": [
    "sidePanel",
    "tabs",
    "scripting",
    "audioCapture"
  ],
  "host_permissions": [
    "https://ergonomics-mu.vercel.app/*",
    "https://*.jd.com/*",
    "https://p.3.cn/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "AI Commerce Agent"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}