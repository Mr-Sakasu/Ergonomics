{
  "manifest_version": 3,
  "name": "E-commerce × AI",
  "version": "1.0.3",
  "description": "AI-Powered E-commerce",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "https://ergonomics-mu.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "AI Commerce Agent"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}